---
import { getCollection, getEntry } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { SITE, HOME, SOCIALS, BLOG } from "@consts";

const intro = await getEntry("home", "intro");
if (!intro) {
  throw new Error("Missing src/content/home/intro.md");
}
const { Content: IntroContent } = await intro.render();

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft && post.data.category === "writing")
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const workPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft && post.data.category === "career")
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const experience = (await getCollection("work"))
  .sort(
    (a, b) =>
      new Date(b.data.dateStart).valueOf() -
      new Date(a.data.dateStart).valueOf(),
  )
  .slice(0, SITE.NUM_WORKS_ON_HOMEPAGE);

const monthYear = (date: Date) =>
  date.toLocaleString("en-US", { month: "long", year: "numeric" });

const experienceDateRange = (startDate: Date, endDate?: Date | string) => {
  const start = monthYear(startDate);
  if (!endDate) return start;
  if (typeof endDate === "string") return `${start} - ${endDate.toLowerCase()}`;
  return `${start} - ${monthYear(endDate)}`;
};
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="flex items-center gap-4 mb-2">
      <img
        src="/me.jpg"
        alt="Portrait of Manoj Kumar"
        width="80"
        height="80"
        class="w-20 h-20 rounded-full border border-black/10 dark:border-white/10 object-cover shrink-0"
      />
      <div class="space-y-1 min-w-0">
        <h4 class="animate font-semibold text-black dark:text-white">
          {intro.data.greeting}
        </h4>
        {
          intro.data.tagline && (
            <p class="animate text-sm font-medium text-black/80 dark:text-white/90">
              {intro.data.tagline}
            </p>
          )
        }
      </div>
    </div>
    <div class="space-y-16">
      <section>
        <article class="space-y-4 animate prose dark:prose-invert max-w-none prose-p:animate prose-p:my-0 prose-p:not-last:mb-4">
          <IntroContent />
          {
            intro.data.location && (
              <p class="text-sm opacity-75 !mt-4">
                {intro.data.location} ·
                <Link href="/resume.pdf" aria-label="Download resume">
                  Resume (PDF)
                </Link>
              </p>
            )
          }
        </article>
      </section>

      {
        blog.length > 0 && (
          <section class="animate space-y-6">
            <div class="flex flex-wrap gap-y-2 items-center justify-between">
              <h5 class="font-semibold text-black dark:text-white">{BLOG.TITLE}</h5>
              <Link href="/blog">See all posts</Link>
            </div>
            <ul class="flex flex-col gap-0">
              {
                blog.map((post) => (
                  <li>
                    <ArrowCard entry={post} />
                  </li>
                ))
              }
            </ul>
          </section>
        )
      }

      {
        workPosts.length > 0 && (
          <section class="animate space-y-6">
            <div class="flex flex-wrap gap-y-2 items-center justify-between">
              <h5 class="font-semibold text-black dark:text-white">Work</h5>
              <Link href="/work">See all work</Link>
            </div>
            <ul class="flex flex-col gap-0">
              {
                workPosts.map((post) => (
                  <li>
                    <ArrowCard entry={post} />
                  </li>
                ))
              }
            </ul>
          </section>
        )
      }

      {
        experience.length > 0 && (
          <section id="experience" class="animate space-y-6">
            <div class="flex flex-wrap gap-y-2 items-center justify-between">
              <h5 class="font-semibold text-black dark:text-white">Experience</h5>
              <Link href="/resume.pdf">View resume</Link>
            </div>
            <ul class="flex flex-col gap-0">
              {
                experience.map((entry) => (
                  <li class="py-3 sm:py-3.5 -mx-1 px-1">
                    <div class="min-w-0 flex-1 space-y-1">
                      <div class="font-semibold text-black dark:text-white">
                        {entry.data.role}
                      </div>
                      <p class="text-sm text-black/65 dark:text-white/65 leading-snug">
                        {entry.data.company}
                      </p>
                      <p class="text-sm text-black/55 dark:text-white/55 leading-snug">
                        {experienceDateRange(entry.data.dateStart, entry.data.dateEnd)}
                      </p>
                    </div>
                  </li>
                ))
              }
            </ul>
          </section>
        )
      }

      <section class="animate space-y-4">
        <h5 class="font-semibold text-black dark:text-white">Connect</h5>
        <ul class="flex flex-wrap gap-2">
          {
            SOCIALS.map((SOCIAL) => (
              <li class="flex gap-x-2 text-nowrap">
                <Link
                  href={SOCIAL.HREF}
                  external={SOCIAL.HREF.startsWith("http")}
                  aria-label={`${SITE.NAME} ${SOCIAL.NAME}`}
                >
                  {SOCIAL.NAME}
                </Link>
                {"/"}
              </li>
            ))
          }
          {
            SITE.EMAIL && (
              <li class="line-clamp-1">
                <Link
                  href={`mailto:${SITE.EMAIL}`}
                  aria-label={`Email ${SITE.NAME}`}
                >
                  {SITE.EMAIL}
                </Link>
              </li>
            )
          }
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>
