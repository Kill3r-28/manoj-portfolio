---
interface Props {
  date: Date;
  /** full = "Jan 15, 2024"; monthYear = "Jan 2024" (minimal list rows) */
  format?: "full" | "monthYear";
}

const { date, format = "full" } = Astro.props;

const full = date.toLocaleDateString("en-us", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const monthYear = date.toLocaleDateString("en-us", {
  month: "short",
  year: "numeric",
});
---

<time datetime={date.toISOString()}>
  {format === "monthYear" ? monthYear : full}
</time>
