---
interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<section
  class="post-engagement animate mt-16 pt-10 border-t border-black/10 dark:border-white/10"
  data-post-slug={postSlug}
  aria-label="Post reactions"
>
  <div class="flex flex-wrap items-center gap-4 mb-8">
    <button
      type="button"
      data-upvote-btn
      class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/5 text-black dark:text-white transition-colors duration-300 disabled:opacity-50 disabled:cursor-not-allowed"
      aria-pressed="false"
    >
      <span aria-hidden="true">▲</span>
      <span data-upvote-label>Upvote</span>
      <span data-upvote-count class="tabular-nums opacity-75">0</span>
    </button>
    <p data-engagement-status class="text-sm opacity-60 hidden" role="status"></p>
  </div>

  <div class="space-y-6">
    <h2 class="text-lg font-semibold text-black dark:text-white">Comments</h2>

    <form data-comment-form class="space-y-4 max-w-xl">
      <div class="sr-only" aria-hidden="true">
        <label for="website">Website</label>
        <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
      </div>
      <div>
        <label
          for="comment-name"
          class="block text-sm font-medium text-black dark:text-white mb-1"
        >
          Name
        </label>
        <input
          id="comment-name"
          name="name"
          type="text"
          required
          maxlength="80"
          autocomplete="name"
          placeholder="Your name"
          class="w-full px-3 py-2 rounded-lg border border-black/15 dark:border-white/20 bg-transparent text-black dark:text-white placeholder:opacity-50 focus:outline-none focus:ring-1 focus:ring-black/20 dark:focus:ring-white/30"
        />
      </div>
      <div>
        <label
          for="comment-body"
          class="block text-sm font-medium text-black dark:text-white mb-1"
        >
          Comment
        </label>
        <textarea
          id="comment-body"
          name="body"
          required
          maxlength="2000"
          rows="4"
          placeholder="Share your thoughts…"
          class="w-full px-3 py-2 rounded-lg border border-black/15 dark:border-white/20 bg-transparent text-black dark:text-white placeholder:opacity-50 focus:outline-none focus:ring-1 focus:ring-black/20 dark:focus:ring-white/30 resize-y"
        ></textarea>
      </div>
      <button
        type="submit"
        class="px-4 py-2 rounded-lg border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/5 text-black dark:text-white transition-colors duration-300 disabled:opacity-50"
      >
        Post comment
      </button>
      <p data-comment-form-status class="text-sm opacity-75 hidden" role="status"></p>
    </form>

    <ul data-comment-list class="space-y-4 list-none p-0 m-0">
      <li data-comment-empty class="text-sm opacity-60">No comments yet. Be the first.</li>
    </ul>
  </div>
</section>

<script>
  interface Comment {
    id: string;
    name: string;
    body: string;
    createdAt: string;
  }

  const VOTER_KEY = "portfolio-voter-id";

  function getVoterId(): string {
    let id = localStorage.getItem(VOTER_KEY);
    if (!id) {
      id = crypto.randomUUID();
      localStorage.setItem(VOTER_KEY, id);
    }
    return id;
  }

  function apiBase() {
    return "/.netlify/functions";
  }

  function escapeHtml(text: string) {
    const el = document.createElement("span");
    el.textContent = text;
    return el.innerHTML;
  }

  function formatDate(iso: string) {
    try {
      return new Intl.DateTimeFormat(undefined, {
        dateStyle: "medium",
        timeStyle: "short",
      }).format(new Date(iso));
    } catch {
      return iso;
    }
  }

  function initEngagement(root: HTMLElement) {
    if (!root.dataset.postSlug) return;
    const postSlug = root.dataset.postSlug;

    const upvoteBtn = root.querySelector<HTMLButtonElement>("[data-upvote-btn]");
    const upvoteCount = root.querySelector("[data-upvote-count]");
    const upvoteLabel = root.querySelector("[data-upvote-label]");
    const engagementStatus = root.querySelector("[data-engagement-status]");
    const commentForm = root.querySelector<HTMLFormElement>("[data-comment-form]");
    const commentList = root.querySelector("[data-comment-list]");
    const commentEmpty = root.querySelector("[data-comment-empty]");
    const formStatus = root.querySelector("[data-comment-form-status]");

    const voterId = getVoterId();
    let apiAvailable = true;

    function setStatus(el: Element | null, message: string, isError = false) {
      if (!el) return;
      el.textContent = message;
      el.classList.toggle("hidden", !message);
      el.classList.toggle("text-red-600", isError);
      el.classList.toggle("dark:text-red-400", isError);
    }

    async function loadUpvotes() {
      try {
        const res = await fetch(
          `${apiBase()}/upvote?slug=${encodeURIComponent(postSlug)}&voterId=${encodeURIComponent(voterId)}`,
          { credentials: "include" },
        );
        if (!res.ok) throw new Error("upvote fetch failed");
        const data = (await res.json()) as { count: number; voted: boolean };
        if (upvoteCount) upvoteCount.textContent = String(data.count);
        if (upvoteBtn) {
          upvoteBtn.disabled = data.voted;
          upvoteBtn.setAttribute("aria-pressed", String(data.voted));
        }
        if (upvoteLabel && data.voted) upvoteLabel.textContent = "Upvoted";
      } catch {
        apiAvailable = false;
        if (upvoteBtn) upvoteBtn.disabled = true;
        setStatus(
          engagementStatus,
          "Upvotes and comments work on the deployed site (Netlify).",
        );
      }
    }

    async function loadComments() {
      if (!commentList) return;
      try {
        const res = await fetch(
          `${apiBase()}/comments?slug=${encodeURIComponent(postSlug)}`,
          { credentials: "include" },
        );
        if (!res.ok) throw new Error("comments fetch failed");
        const data = (await res.json()) as { comments: Comment[] };
        renderComments(data.comments);
      } catch {
        apiAvailable = false;
        if (commentForm) commentForm.classList.add("hidden");
        setStatus(
          engagementStatus,
          "Upvotes and comments work on the deployed site (Netlify).",
        );
      }
    }

    function renderComments(comments: Comment[]) {
      if (!commentList || !commentEmpty) return;

      commentList
        .querySelectorAll("[data-comment-item]")
        .forEach((el) => el.remove());

      if (comments.length === 0) {
        commentEmpty.classList.remove("hidden");
        return;
      }

      commentEmpty.classList.add("hidden");

      for (const comment of comments) {
        const li = document.createElement("li");
        li.dataset.commentItem = "";
        li.className =
          "p-4 rounded-lg border border-black/10 dark:border-white/10 space-y-1";
        li.innerHTML = `
          <div class="font-semibold text-black dark:text-white">${escapeHtml(comment.name)}</div>
          <time class="text-xs opacity-60" datetime="${comment.createdAt}">${formatDate(comment.createdAt)}</time>
          <p class="text-sm mt-2 whitespace-pre-wrap">${escapeHtml(comment.body)}</p>
        `;
        commentList.appendChild(li);
      }
    }

    upvoteBtn?.addEventListener("click", async () => {
      if (!apiAvailable || upvoteBtn.disabled) return;
      upvoteBtn.disabled = true;
      try {
        const res = await fetch(`${apiBase()}/upvote?slug=${encodeURIComponent(postSlug)}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ voterId }),
          credentials: "include",
        });
        if (!res.ok) throw new Error("upvote failed");
        const data = (await res.json()) as { count: number; voted: boolean };
        if (upvoteCount) upvoteCount.textContent = String(data.count);
        upvoteBtn.setAttribute("aria-pressed", "true");
        if (upvoteLabel) upvoteLabel.textContent = "Upvoted";
        setStatus(engagementStatus, "");
      } catch {
        upvoteBtn.disabled = false;
        setStatus(engagementStatus, "Could not register upvote. Try again.", true);
      }
    });

    commentForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!apiAvailable) return;

      const fd = new FormData(commentForm);
      const name = String(fd.get("name") ?? "").trim();
      const body = String(fd.get("body") ?? "").trim();
      const website = String(fd.get("website") ?? "").trim();

      const submitBtn = commentForm.querySelector<HTMLButtonElement>(
        'button[type="submit"]',
      );
      if (submitBtn) submitBtn.disabled = true;
      setStatus(formStatus, "Posting…");

      try {
        const res = await fetch(
          `${apiBase()}/comments?slug=${encodeURIComponent(postSlug)}`,
          {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ name, body, website }),
            credentials: "include",
          },
        );
        const data = (await res.json()) as { error?: string; comment?: Comment };
        if (!res.ok) {
          throw new Error(data.error ?? "Failed to post comment");
        }
        commentForm.reset();
        setStatus(formStatus, "Comment posted. Thank you!");
        await loadComments();
      } catch (err) {
        setStatus(
          formStatus,
          err instanceof Error ? err.message : "Could not post comment.",
          true,
        );
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });

    loadUpvotes();
    loadComments();
  }

  function boot() {
    document
      .querySelectorAll<HTMLElement>(".post-engagement[data-post-slug]")
      .forEach(initEngagement);
  }

  boot();
  document.addEventListener("astro:page-load", boot);
</script>
