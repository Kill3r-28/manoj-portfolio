# Copy to .env for local Netlify dev (optional). On Netlify, set in Site → Environment variables.

# Same secret for: ?owner=SECRET (sets cookie), Bearer token on admin API, DELETE comments.
PORTFOLIO_OWNER_SECRET=change-me-to-a-long-random-string

# Local-only: read/write engagement data to .data/ instead of Blobs
# USE_LOCAL_ENGAGEMENT=true
